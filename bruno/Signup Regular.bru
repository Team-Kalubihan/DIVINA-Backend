meta {
  name: Signup Regular
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "first_name": "John",
    "last_name": "Doe",
    "email": "johndoe@email.com",
    "password": "secret123",
    "is_dive_operator": false
  }
}

vars:pre-request {
  base_url: 127.0.0.1:5000
}
